--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=yakuake
-pkgver=23.08.4
+pkgver=23.08.3
 pkgrel=1
 pkgdesc='A drop-down terminal emulator based on KDE konsole technology'
