--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -4,7 +4,7 @@
 pkgrel=10
 pkgdesc='A very powerful batch file renamer'
 arch=(x86_64)
-url='https://apps.kde.org/krename/'
+url='https://www.krename.net'
 license=(GPL-2.0-or-later)
 depends=(exiv2
          freetype2
@@ -49,7 +49,7 @@
 }
 
 build() {
-  cmake -B build -S $pkgname-$pkgver \
+  artix-cmake -B build -S $pkgname-$pkgver \
     -DBUILD_TESTING=OFF
   cmake --build build
 }


