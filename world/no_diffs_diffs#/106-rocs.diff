--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=rocs
-pkgver=23.08.0
+pkgver=23.04.3
 pkgrel=1
 pkgdesc='Graph Theory IDE'
 url='https://apps.kde.org/rocs/'
@@ -10,14 +10,14 @@
 depends=(grantlee ktexteditor qt5-xmlpatterns qt5-script hicolor-icon-theme)
 makedepends=(extra-cmake-modules kdoctools boost)
 source=(https://download.kde.org/stable/release-service/$pkgver/src/$pkgname-$pkgver.tar.xz{,.sig})
-sha256sums=('b8cf105131cfc6f19e06cb1fa4fcd42b510f304f7cd2f2afc28b7fbcd4de0a96'
+sha256sums=('ab2e8ce85b3299c4e35c358eb7d57962aff99c2233badbe6c18e7acda2ee7f8d'
             'SKIP')
 validpgpkeys=(CA262C6C83DE4D2FB28A332A3A6A4DB839EAA6D7  # Albert Astals Cid <aacid@kde.org>
               F23275E4BF10AFC1DF6914A6DBD2CE893E2D1C87  # Christoph Feck <cfeck@kde.org>
               D81C0CB38EB725EF6691C385BB463350D6EF31EF) # Heiko Becker <heiko.becker@kde.org>
 
 build() {
-  cmake -B build -S $pkgname-$pkgver \
+  artix-cmake -B build -S $pkgname-$pkgver \
     -DBUILD_TESTING=OFF
   cmake --build build
 }


