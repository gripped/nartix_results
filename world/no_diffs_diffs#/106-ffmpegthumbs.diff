--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=ffmpegthumbs
-pkgver=23.08.3
+pkgver=23.08.2
 pkgrel=1
 pkgdesc='FFmpeg-based thumbnail creator for video files'
