--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=kshisen
-pkgver=23.08.0
+pkgver=23.04.3
 pkgrel=1
 pkgdesc='A solitaire-like game played using the standard set of Mahjong tiles'
 url='https://apps.kde.org/kshisen/'
@@ -10,14 +10,14 @@
 depends=(libkdegames libkmahjongg hicolor-icon-theme)
 makedepends=(extra-cmake-modules kdoctools)
 source=(https://download.kde.org/stable/release-service/$pkgver/src/$pkgname-$pkgver.tar.xz{,.sig})
-sha256sums=('b67072105559ece54a388d455a1cd12f50e0a2cdec64378abbd5e88fc7248cdc'
+sha256sums=('e8c7067010f7d21dea799b8a284c2a71f960ecd88d1d073b76ba0cca9735d32d'
             'SKIP')
 validpgpkeys=(CA262C6C83DE4D2FB28A332A3A6A4DB839EAA6D7  # Albert Astals Cid <aacid@kde.org>
               F23275E4BF10AFC1DF6914A6DBD2CE893E2D1C87  # Christoph Feck <cfeck@kde.org>
               D81C0CB38EB725EF6691C385BB463350D6EF31EF) # Heiko Becker <heiko.becker@kde.org>
 
 build() {
-  cmake -B build -S $pkgname-$pkgver \
+  artix-cmake -B build -S $pkgname-$pkgver \
     -DBUILD_TESTING=OFF
   cmake --build build
 }


