--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -17,7 +17,7 @@
 options=(!lto) # https://bugs.kde.org/show_bug.cgi?id=411425
 
 build() {
-  cmake -B build -S $pkgname-$pkgver \
+  artix-cmake -B build -S $pkgname-$pkgver \
     -DBUILD_TESTING=OFF
   cmake --build build
 }


