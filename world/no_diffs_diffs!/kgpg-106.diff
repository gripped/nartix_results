--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=kgpg
-pkgver=23.08.0
+pkgver=23.04.3
 pkgrel=1
 pkgdesc='A GnuPG frontend'
