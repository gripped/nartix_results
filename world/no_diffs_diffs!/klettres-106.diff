--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=klettres
-pkgver=23.08.3
+pkgver=23.08.2
 pkgrel=1
 pkgdesc='Learn The Alphabet'
