--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=ktuberling
-pkgver=23.08.3
+pkgver=23.08.2
 pkgrel=1
 pkgdesc='A simple constructor game suitable for children and adults alike'
