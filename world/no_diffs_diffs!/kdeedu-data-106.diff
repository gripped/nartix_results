--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=kdeedu-data
-pkgver=23.08.2
+pkgver=23.04.3
 pkgrel=1
 pkgdesc='Common data for KDE Edu applications'
