--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=kcron
-pkgver=23.08.1
+pkgver=23.04.3
 pkgrel=1
 pkgdesc='Configure and schedule tasks'
 url='https://apps.kde.org/kcron/'
@@ -8,16 +8,16 @@
 license=(GPL LGPL FDL)
 groups=(kde-applications kde-system)
 depends=(kio cron)
-makedepends=(extra-cmake-modules kdoctools kcmutils)
+makedepends=(extra-cmake-modules kdoctools)
 source=(https://download.kde.org/stable/release-service/$pkgver/src/$pkgname-$pkgver.tar.xz{,.sig})
-sha256sums=('56cdd58db91e514611110eeadcac95c9c54a17959470a96e8189d6a6f61049e8'
+sha256sums=('efed01ccebee178e12381360eb33e54ff98dc1940745b454ecf33fd20ae9f980'
             'SKIP')
 validpgpkeys=(CA262C6C83DE4D2FB28A332A3A6A4DB839EAA6D7  # Albert Astals Cid <aacid@kde.org>
               F23275E4BF10AFC1DF6914A6DBD2CE893E2D1C87  # Christoph Feck <cfeck@kde.org>
               D81C0CB38EB725EF6691C385BB463350D6EF31EF) # Heiko Becker <heiko.becker@kde.org>
 
 build() {
-  cmake -B build -S $pkgname-$pkgver \
+  artix-cmake -B build -S $pkgname-$pkgver \
     -DBUILD_TESTING=OFF
   cmake --build build
 }


