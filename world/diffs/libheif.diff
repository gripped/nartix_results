--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,12 +1,13 @@
 
 pkgname=libheif
-pkgver=1.16.2
-pkgrel=3
+pkgver=1.17.0
+pkgrel=1
 pkgdesc='An HEIF and AVIF file format decoder and encoder'
 arch=(x86_64)
 url='https://github.com/strukturag/libheif'
 license=(GPL3)
 makedepends=(cmake
+             dav1d
              gdk-pixbuf2
              libjpeg
              libpng
@@ -15,20 +16,23 @@
 depends=(aom
          gcc-libs
          glibc
-         dav1d
          libde265
+         libwebp
          x265)
 optdepends=('libjpeg: for heif-convert and heif-enc'
             'libpng: for heif-convert and heif-enc'
+            'dav1d: dav1d encoder'
             'rav1e: rav1e encoder'
             'svt-av1: svt-av1 encoder')
 source=(https://github.com/strukturag/libheif/releases/download/v$pkgver/libheif-$pkgver.tar.gz)
-sha256sums=('7f97e4205c0bd9f9b8560536c8bd2e841d1c9a6d610401eb3eb87ed9cdfe78ea')
+sha256sums=('c86661e9ef9c43ad8de9d2b38b7b508df5322580b24d22fc25a977e7fdb26f3c')
 
 build() {
-  cmake -B build -S $pkgname-$pkgver\
+  cmake -B build -S $pkgname-$pkgver \
     -DCMAKE_INSTALL_PREFIX=/usr \
-    -DAOM_ENCODER=ON
+    -DWITH_DAV1D=ON \
+    -DWITH_RAV1E=ON \
+    -DWITH_SvtEnc=ON
   cmake --build build
 }
 


