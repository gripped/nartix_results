 package() {
   meson install -C build --destdir "$pkgdir"
   install -Dm644 ${srcdir}/xapp-portals.conf  ${pkgdir}/usr/share/xdg-desktop-portal/xapp-portals.conf
+
+  rm -r $pkgdir/usr/lib/systemd
 }


