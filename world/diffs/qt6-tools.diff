--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,37 +1,28 @@
 
 pkgname=qt6-tools
-_qtver=6.6.0
+_qtver=6.5.2
 pkgver=${_qtver/-/}
 pkgrel=1
 arch=(x86_64)
 url='https://www.qt.io'
 license=(GPL3 LGPL3 FDL custom)
 pkgdesc='A cross-platform application and UI framework (Development Tools, QtHelp)'
-depends=(gcc-libs
-         glibc
-         qt6-base
-         zstd)
-makedepends=(clang
-             cmake
-             llvm
-             ninja
-             qt6-declarative)
-optdepends=('clang: for qdoc and lupdate'
-            'qt6-declarative: for qdoc and lupdate')
+depends=(qt6-base)
+makedepends=(cmake ninja qt6-declarative clang llvm) # litehtml
+optdepends=('qt6-declarative: for qdoc and lupdate' 'clang: for qdoc and lupdate') # 'litehtml: for assistant'
 groups=(qt6)
 _pkgfn=${pkgname/6-/}-everywhere-src-$_qtver
-source=(https://download.qt.io/official_releases/qt/${pkgver%.*}/$_qtver/submodules/$_pkgfn.tar.xz
-        zstd-target.patch)
-sha256sums=('4e9feebc142bbb6e453e1dc3277e09ec45c8ef081b5ee2a029e6684b5905ba99'
-            '876b46461670d21b07d0e6a2ea53311d3c16be9e6fc3746f52b74e687f4eac8b')
+source=(https://download.qt.io/official_releases/qt/${pkgver%.*}/$_qtver/submodules/$_pkgfn.tar.xz)
+sha256sums=('551ffb22751d8fd4d88e9ebd55b9131f4ca55341ee497fdbbba4da8d10d94341')
 
 prepare() {
   sed -e '/qt_internal_set_exceptions_flags/d' -e '/qt_disable_warnings/d' -i $_pkgfn/src/assistant/CMakeLists.txt
-  patch -d $_pkgfn -p1 < zstd-target.patch
 }
 
 build() {
   cmake -B build -S $_pkgfn -G Ninja \
+    -DCMAKE_INSTALL_PREFIX=/usr \
+    -DCMAKE_PREFIX_PATH=/usr \
     -DINSTALL_PUBLICBINDIR=usr/bin \
     -DCMAKE_MESSAGE_LOG_LEVEL=STATUS
   cmake --build build


