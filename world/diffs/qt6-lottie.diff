--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,26 +1,22 @@
 
 pkgname=qt6-lottie
-_qtver=6.6.0
+_qtver=6.5.2
 pkgver=${_qtver/-/}
 pkgrel=1
 arch=(x86_64)
 url='https://www.qt.io'
 license=(GPL3 LGPL3 FDL custom)
 pkgdesc='A family of player software for a certain json-based file format for describing 2d vector graphics animations'
-depends=(gcc-libs
-         glibc
-         qt6-base)
-makedepends=(cmake
-             ninja
-             qt6-declarative)
+depends=(qt6-base)
+makedepends=(cmake ninja qt6-declarative)
 optdepends=('qt6-declarative: QML bindings')
 groups=(qt6)
 _pkgfn=${pkgname/6-/}-everywhere-src-$_qtver
 source=(https://download.qt.io/official_releases/qt/${pkgver%.*}/$_qtver/submodules/$_pkgfn.tar.xz)
-sha256sums=('1d98b45107a4b9a6337bc7ac37b9e54cdaa68110f814d93eecc8fbf8d338f84f')
+sha256sums=('003adc5cf0d50b32d00a09d66ba6332db22191fb0999f51e032f02a21474e89b')
 
 build() {
-  cmake -B build -S $_pkgfn -G Ninja \
+  cmake -B build -S $_pkgfn -G Ninja  -DCMAKE_INSTALL_PREFIX=/usr \
     -DCMAKE_MESSAGE_LOG_LEVEL=STATUS
   cmake --build build
 }


