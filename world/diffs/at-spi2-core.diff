--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -17,7 +17,7 @@
   libx11
   libxml2
   libxtst
-  systemd
+  libelogind
   xorg-xprop
 )
 makedepends=(
@@ -50,7 +50,7 @@
     -D docs=true
   )
 
-  arch-meson at-spi2-core build "${meson_options[@]}"
+  artix-meson at-spi2-core build "${meson_options[@]}"
