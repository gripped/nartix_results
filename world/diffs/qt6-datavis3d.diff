--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,26 +1,22 @@
 
 pkgname=qt6-datavis3d
-_qtver=6.6.0
+_qtver=6.5.2
 pkgver=${_qtver/-/}
 pkgrel=1
 arch=(x86_64)
 url='https://www.qt.io'
 license=(GPL3 LGPL3 FDL custom)
 pkgdesc='Qt6 Data Visualization module'
-depends=(gcc-libs
