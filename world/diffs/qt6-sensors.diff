--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,27 +1,23 @@
 
 pkgname=qt6-sensors
-_qtver=6.6.0
+_qtver=6.5.2
 pkgver=${_qtver/-/}
 pkgrel=1
 arch=(x86_64)
 url='https://www.qt.io'
 license=(GPL3 LGPL3 FDL custom)
 pkgdesc='Provides access to sensor hardware and motion gesture recognition'
-depends=(gcc-libs
-         glibc
-         qt6-base)
-makedepends=(cmake
-             ninja
-             qt6-declarative)
+depends=(qt6-connectivity)
+makedepends=(cmake ninja qt6-declarative)
 optdepends=('qt6-declarative: QML bindings'
             'iio-sensor-proxy: iio-sensor-proxy backend')
 groups=(qt6)
 _pkgfn=${pkgname/6-/}-everywhere-src-$_qtver
 source=(https://download.qt.io/official_releases/qt/${pkgver%.*}/$_qtver/submodules/$_pkgfn.tar.xz)
-sha256sums=('28f0be5d4eac103ba3bb660ea61806d0e193c1fab949d1c95f2cb7cb39d84498')
+sha256sums=('4006bd7cfbb4302a887bda82b7fe3c31633626363a5e6ba9730bdb4fa8ab2aa6')
 
 build() {
-  cmake -B build -S $_pkgfn -G Ninja \
+  cmake -B build -S $_pkgfn -G Ninja  -DCMAKE_INSTALL_PREFIX=/usr \
     -DCMAKE_MESSAGE_LOG_LEVEL=STATUS
   cmake --build build
 }


