--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,48 +1,33 @@
 
+_pkg=pam-wrapper
 pkgname=pam_wrapper
-pkgver=1.1.5
-pkgrel=1
+pkgver=1.1.4
+pkgrel=4
