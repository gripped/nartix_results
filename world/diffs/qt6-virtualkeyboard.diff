--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,27 +1,21 @@
 
 pkgname=qt6-virtualkeyboard
-_qtver=6.6.0
+_qtver=6.5.2
 pkgver=${_qtver/-/}
 pkgrel=1
 arch=(x86_64)
 url='https://www.qt.io'
 license=(GPL3 LGPL3 FDL custom)
 pkgdesc='Virtual keyboard framework'
-depends=(gcc-libs
-         glibc
-         hunspell
-         qt6-base
-         qt6-declarative
-         qt6-svg)
-makedepends=(cmake
-             ninja)
+depends=(qt6-declarative qt6-svg hunspell)
+makedepends=(cmake ninja)
 groups=(qt6)
 _pkgfn=${pkgname/6-/}-everywhere-src-$_qtver
 source=(https://download.qt.io/official_releases/qt/${pkgver%.*}/$_qtver/submodules/$_pkgfn.tar.xz)
-sha256sums=('2784db43f514bfd3a2ce0e79e0096deea95a3866254d376a9134bc512bfa777b')
+sha256sums=('0570e0387e22a526b8ff735355ca8f09347501b71f7ae2166b60a81a40626269')
 
 build() {
-  cmake -B build -S $_pkgfn -G Ninja \
+  cmake -B build -S $_pkgfn -G Ninja  -DCMAKE_INSTALL_PREFIX=/usr \
     -DCMAKE_MESSAGE_LOG_LEVEL=STATUS \
     -DQT_FEATURE_vkb_arrow_keynavigation=ON
   cmake --build build


