--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,25 +1,21 @@
 
 pkgname=qt6-serialbus
-_qtver=6.6.0
+_qtver=6.5.2
 pkgver=${_qtver/-/}
 pkgrel=1
 arch=(x86_64)
 url='https://www.qt.io'
 license=(GPL3 LGPL3 FDL custom)
 pkgdesc='Qt module for general purpose serial bus access'
-depends=(gcc-libs
-         glibc
-         qt6-base
-         qt6-serialport)
-makedepends=(cmake
-             ninja)
+depends=(qt6-serialport)
+makedepends=(cmake ninja)
 groups=(qt6)
 _pkgfn=${pkgname/6-/}-everywhere-src-$_qtver
 source=(https://download.qt.io/official_releases/qt/${pkgver%.*}/$_qtver/submodules/$_pkgfn.tar.xz)
-sha256sums=('18ccf07152ea995c6c1ef3ce9120b6baea7017a09626ec1c5bf4faa6dd29b94c')
+sha256sums=('f0426307cdc185547ad6331a670187d180cce4c11254d6a26aa997fe03b7cdfe')
 
 build() {
-  cmake -B build -S $_pkgfn -G Ninja \
+  cmake -B build -S $_pkgfn -G Ninja  -DCMAKE_INSTALL_PREFIX=/usr \
     -DCMAKE_MESSAGE_LOG_LEVEL=STATUS
   cmake --build build
 }


