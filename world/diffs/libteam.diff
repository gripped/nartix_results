   cd libteam
+
+  git cherry-pick -n 61efd6de2fbb8ee077863ee5a355ac3dfd9365b9
+
   NOCONFIGURE=1 ./autogen.sh
 }
 
 build() {
-  local configure_options=(
-    --prefix=/usr
-    --sysconfdir=/etc
-    --localstatedir=/var
-    --libexecdir=/usr/lib
