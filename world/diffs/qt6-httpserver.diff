--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=qt6-httpserver
-_qtver=6.6.1
+_qtver=6.6.0
 pkgver=${_qtver/-/}
 pkgrel=1
