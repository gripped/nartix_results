--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,31 +1,22 @@
 
 pkgname=freetds
-pkgver=1.4.3
+pkgver=1.3.18
 pkgrel=1
 pkgdesc='Library for accessing Sybase and MS SQL Server databases'
 url='https://www.freetds.org'
 arch=(x86_64)
 license=(LGPL)
-depends=(glibc
-         krb5
-         openssl
-         readline
-         unixodbc)
+depends=(openssl unixodbc)
 backup=(etc/freetds/freetds.conf
         etc/freetds/locales.conf
         etc/freetds/pool.conf)
 source=(ftp://ftp.freetds.org/pub/freetds/stable/$pkgname-$pkgver.tar.bz2)
-sha256sums=('12f8b55b1e1816aec60e0d067de939c09e3477363250be95755b9b36e1c3c5d3')
+sha256sums=('1d8561d57c71991a28f4681343785c23a6a3eb54d5bcd23897d07e3825ff2d56')
 
 build() {
   cd $pkgname-$pkgver
-  ./configure \
-    --prefix=/usr \
-    --sysconfdir=/etc/freetds \
-    --enable-msdblib \
-    --enable-krb5 \
-    --with-unixodbc=/usr \
-    --with-openssl
+  ./configure --prefix=/usr --sysconfdir=/etc/freetds --enable-msdblib \
+    --with-unixodbc=/usr --with-openssl
   make
 }
 


