@@ -1,13 +1,12 @@
 
 pkgname=wlroots
-pkgver=0.17.0
-pkgrel=1
+pkgver=0.16.2
+pkgrel=2
 license=('MIT')
 pkgdesc='Modular Wayland compositor library'
