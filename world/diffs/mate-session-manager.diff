             'xdg-user-dirs-gtk: manage user directories')
 groups=('mate')
@@ -23,7 +23,7 @@
         	--libexecdir=/usr/lib/${pkgname} \
         	--sysconfdir=/etc \
         	--localstatedir=/var \
-        	--disable-upower
+        	--with-elogind=yes
     	make
 }
 


