 build() {
   cd numpy-$pkgver
   CFLAGS+=" -ffat-lto-objects" \
   CXXFLAGS+=" -ffat-lto-objects" \
   python -m build --wheel --no-isolation \
-    -Csetup-args="-Dblas=cblas" \
+    -Csetup-args="-Dblas=blas" \
     -Csetup-args="-Dlapack=lapack"
 }
 


