--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -1,6 +1,6 @@
 
 pkgname=kigo
-pkgver=23.08.2
+pkgver=23.04.3
 pkgrel=1
 pkgdesc='An open-source implementation of the popular Go game'
 url='https://apps.kde.org/kigo/'
@@ -8,16 +8,16 @@
 license=(GPL LGPL FDL)
 groups=(kde-applications kde-games)
 depends=(libkdegames gnugo hicolor-icon-theme)
-makedepends=(extra-cmake-modules kdoctools5)
+makedepends=(extra-cmake-modules kdoctools)
 source=(https://download.kde.org/stable/release-service/$pkgver/src/$pkgname-$pkgver.tar.xz{,.sig})
-sha256sums=('43eadadb5f5eb1523886976f30d36f45b365907cfbb218237863432d682cb2e4'
+sha256sums=('c3ec67e07cce1a131643631f9c94bd844b5fea5c62edd7320802a1a233bda963'
             'SKIP')
 validpgpkeys=(CA262C6C83DE4D2FB28A332A3A6A4DB839EAA6D7  # Albert Astals Cid <aacid@kde.org>
               F23275E4BF10AFC1DF6914A6DBD2CE893E2D1C87  # Christoph Feck <cfeck@kde.org>
               D81C0CB38EB725EF6691C385BB463350D6EF31EF) # Heiko Becker <heiko.becker@kde.org>
 
 build() {
-  cmake -B build -S $pkgname-$pkgver \
+  artix-cmake -B build -S $pkgname-$pkgver \
     -DBUILD_TESTING=OFF
   cmake --build build
 }


