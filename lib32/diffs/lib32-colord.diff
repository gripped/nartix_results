--- Arch PKGBUILD
+++ Artix PKGBUILD
@@ -9,7 +9,7 @@
 depends=(
   libcolord
   lib32-glib2
-  lib32-systemd
+  lib32-elogind
   lib32-lcms2
 )
 makedepends=(
@@ -50,7 +50,7 @@
   export CXX='g++ -m32'
   export PKG_CONFIG=i686-pc-linux-gnu-pkg-config
 
-  arch-meson colord build \
+  artix-meson colord build \
     --libdir=/usr/lib32 \
     -D docs=false \
     -D man=false \
@@ -60,7 +60,8 @@
     -D introspection=false \
     -D vapi=false \
     -D print_profiles=false \
-    -D daemon_user=colord
+    -D daemon_user=colord \
+    -D systemd=false
   meson compile -C build
 }
 


