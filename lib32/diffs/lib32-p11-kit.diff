@@ -40,6 +38,7 @@
   local meson_options=(
     --libdir /usr/lib32
     -D bash_completion=disabled
+    -D systemd=disabled
     -D trust_paths=/etc/ca-certificates/trust-source:/usr/share/ca-certificates/trust-source
